# ==========================================
# LLAMA-SERVER: SHARED CONFIGURATION & REFERENCE
# Sourced before every preset (see tools/_env.py). Any value here can be
# overridden per-invocation, e.g. LLAMA_CTX_SIZE=16384 ./llama-tool.py run <preset>.
# ==========================================

# ==========================================
# LLAMA.CPP ENGINE (vendored locally, not LM Studio)
# Run ./llama-tool.py engine install to fetch the latest release, list to
# see what's installed, check to see if an update is available, and use
# <tag> to switch versions instantly without re-downloading.
# ==========================================
LLAMA_ENV_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Which installed version to run: "current" (whatever update-llama-cpp.sh
# last activated), or a specific tag (e.g. "b9964") to pin a preset to an
# exact engine build regardless of what's newest.
: "${LLAMA_CPP_VERSION:=current}"

# Path to the Vulkan server binary. Override this directly (e.g. back to an
# LM Studio-managed backend) if you don't want the vendored engine.
: "${LLAMA_BINARY:=${LLAMA_ENV_DIR}/vendor/llama.cpp/${LLAMA_CPP_VERSION}/llama-server}"

# ==========================================
# LOCAL MODEL STORAGE (not LM Studio)
# Run ./llama-tool.py models download <org>/<repo> <file.gguf> to fetch a
# model from Hugging Face into models/<org>/<repo>/ and generate a matching
# preset. list shows what's downloaded, check flags upstream changes,
# delete <preset> removes a model and its preset together.
# ==========================================
: "${LLAMA_MODELS_DIR:=${LLAMA_ENV_DIR}/models}"

# ==========================================
# LOGGING
# Where llama-server's stdout/stderr end up -- must match
# deploy/llama-server.service's StandardOutput=/StandardError= (systemd
# directives can't reference this variable, so keep them in sync by hand
# if you change this). Used as the default log file for
# `llama-tool.py cache stats` and `llama-tool.py log` when no path is given
# on the command line.
# ==========================================
: "${LLAMA_LOG_FILE:=${LLAMA_ENV_DIR}/llama-server.log}"

# ==========================================
# PRESET SELECTOR (Used by Systemd)
# Must match a file name (without .env) under presets/. Run
# `./run-llama.sh --list` to see every available preset with its description.
# ==========================================
ACTIVE_PRESET="qwen3.5-9b"


# ==========================================
# SHARED NETWORK & API
# ==========================================
# LLAMA_HOST: IP address to bind to. (127.0.0.1 for local only, 0.0.0.0 for network access).
LLAMA_HOST="0.0.0.0"
# LLAMA_API_KEY: Bearer token for API access. Deliberately left empty here --
# this file is checked into git. Set the real value via systemd's
# EnvironmentFile= (see deploy/llama-server.service and llama-server.env.example),
# or by exporting it in your shell before running llama-tool.py directly:
#   export LLAMA_API_KEY="..."
: "${LLAMA_API_KEY:=}"


# ==========================================
# SHARED CPU & BATCHING (Integer Ranges)
# ==========================================
# LLAMA_BATCH_SIZE: Logical batch size for prompt processing.
# Range: Integer from 1 to 8192 (Usually 512, 1024, or 2048. Higher = faster prompt eval, uses more VRAM).
LLAMA_BATCH_SIZE="2048"

# LLAMA_UBATCH_SIZE: Physical micro-batch size. Must be less than or equal to BATCH_SIZE.
# Range: Integer from 1 to 2048 (Usually 128, 256, or 512).
LLAMA_UBATCH_SIZE="512"

# LLAMA_THREADS: Number of CPU threads to use for generation.
# Range: Integer from 1 to [Your Max Physical CPU Cores]. Do not exceed physical cores.
LLAMA_THREADS="8"

# LLAMA_PARALLEL: Number of parallel sequences (concurrent users/chats), i.e.
# number of KV-cache slots. Range: Integer from 1 to 32+. (Higher = divides
# your CTX_SIZE among slots, uses more RAM).
# If you're running this behind shuricksumy/llama-slot-proxy, this MUST be
# >= the number of agents in the proxy's config.yaml — each agent is pinned
# to its own id_slot (0-indexed), so a mismatch means some agents share a
# slot and thrash each other's prompt cache instead of staying warm.
LLAMA_PARALLEL="4"

# LLAMA_MAIN_GPU: Which GPU to use as the primary device.
# Range: Integer from 0 to [Number of GPUs - 1]. (0 is the first GPU).
LLAMA_MAIN_GPU="0"

# LLAMA_N_CPU_MOE: Number of Mixture of Experts to run on CPU.
# Range: Integer from 0 to [Model Max Experts]. Usually 0 unless offloading parts of an MoE model to CPU.
LLAMA_N_CPU_MOE="0"


# ==========================================
# SHARED ARCHITECTURE TWEAKS
# ==========================================
# LLAMA_TENSOR_SPLIT: How to split memory across multiple GPUs. 
# Range: "0" (auto), or ratios like "1,2" for 1/3 and 2/3 split.
LLAMA_TENSOR_SPLIT="0"

# LLAMA_SPLIT_MODE: How the model layers are distributed across GPUs.
# Range: "layer" (best for VRAM), "row" (best for compute), "none".
LLAMA_SPLIT_MODE="layer"

# LLAMA_CACHE_TYPE_K / V: Data type for the Context (KV) cache.
# Range: "f16" (Standard), "q8_0" (Saves VRAM, minor precision loss), "q4_0" (Max VRAM savings).
LLAMA_CACHE_TYPE_K="q4_0"
LLAMA_CACHE_TYPE_V="q4_0"

# LLAMA_FLASH_ATTN: Enables Flash Attention (drastically saves VRAM on large context windows).
# Range: "auto", "on" (force on), "off" (force off).
LLAMA_FLASH_ATTN="on"


# ==========================================
# PROMPT CACHE & SLOTS
# Tuned for use behind shuricksumy/llama-slot-proxy: one id_slot per agent,
# each holding its own warm system-prompt cache. See check-cache-reuse.sh to
# verify reuse is actually happening, and llama_cache_stats.py to summarize
# it from server logs.
# ==========================================
# LLAMA_CACHE_PROMPT: reuse a slot's existing KV-cache instead of reprocessing
# the full prompt on every call. Must be "true" for slot-pinned caching (via
# the proxy or a direct id_slot) to have any effect.
LLAMA_CACHE_PROMPT="true"

# LLAMA_CACHE_REUSE: minimum chunk size (tokens) llama-server will try to
# reuse from a slot's cache when the new prompt diverges partway through the
# old one (e.g. same system prompt, new trailing user turn) instead of
# discarding the whole slot and reprocessing from scratch.
LLAMA_CACHE_REUSE="256"

# LLAMA_CACHE_RAM: MB of host RAM reserved for prompt-cache storage across
# all slots. Range: 0 (disabled) upward; scale with LLAMA_PARALLEL and each
# agent's typical context size.
LLAMA_CACHE_RAM="2048"

# LLAMA_SLOT_SAVE_PATH: directory for --slot-save-path. Enables the /slots
# save/restore/erase endpoints so a slot's KV-cache can be persisted to disk
# and survive a server restart, instead of every agent starting cold again.
# Empty = disabled.
LLAMA_SLOT_SAVE_PATH=""

# LLAMA_DEFRAG_THOLD: KV-cache defragmentation threshold (0.0-1.0). Matters
# more the longer several slots stay warm concurrently, which is the normal
# mode of operation when running behind llama-slot-proxy. Empty = disabled.
LLAMA_DEFRAG_THOLD="0.1"


# ==========================================
# SHARED BOOLEAN FLAGS (true/false)
# ==========================================
LLAMA_NO_WEBUI="false"       # Disables the built-in browser UI.
LLAMA_JINJA="true"          # Enables Jinja2 templating for model chats.
LLAMA_LOG_DISABLE="false"    # Disables continuous log output to save disk space.
LLAMA_VERBOSITY="4"        # Integer: 0 to 10. Level of terminal noise/logs.
LLAMA_KV_OFFLOAD="true"     # Offloads KV cache to GPU VRAM (massive speedup).
LLAMA_KV_UNIFIED="true"     # Uses unified memory mapping (excellent for Vulkan/APUs).
LLAMA_NO_DIRECT_IO="true"   # Bypasses direct IO, helpful for stable network drive reading.
LLAMA_MLOCK="true"          # Locks model in RAM so Linux doesn't page it to swap (prevents stuttering).
LLAMA_METRICS="true"        # Opens a /metrics endpoint for performance monitoring.
# Secrets for llama-server.service's EnvironmentFile=. Copy this file to
# llama-server.env (same directory) and fill in real values -- that file is
# gitignored and never committed. Loaded by systemd before ExecStart, so it
# takes effect for llama-tool.py run's `: "${VAR:=default}"` fallbacks in
# llama.env (an already-set value always wins over the default).
#
# For manual/CLI use outside systemd, export these in your shell instead:
#   export LLAMA_API_KEY="..."

LLAMA_API_KEY=

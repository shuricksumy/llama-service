# Qwen3.5-9B (lmstudio-community, Q4_K_M) — good but not fast. Alt source for A/B
# testing against qwen3.5-9b.env. Runs on its own port so both can be up at once.
: "${LLAMA_MODEL:=${LLAMA_MODELS_DIR}/lmstudio-community/Qwen3.5-9B-GGUF/Qwen3.5-9B-Q4_K_M.gguf}"
: "${LLAMA_MMPROJ:=${LLAMA_MODELS_DIR}/lmstudio-community/Qwen3.5-9B-GGUF/mmproj-Qwen3.5-9B-BF16.gguf}"

: "${LLAMA_PORT:=18082}"
: "${LLAMA_CTX_SIZE:=32768}"
: "${LLAMA_N_GPU_LAYERS:=999999}"
: "${LLAMA_OVERRIDE_KV:=}"
: "${LLAMA_REASONING:=off}"
LLAMA_THREADS="8"
LLAMA_PARALLEL="4"

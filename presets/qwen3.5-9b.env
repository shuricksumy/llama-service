# Qwen3.5-9B (unsloth, Q4_K_M) — known-good baseline, previously the default preset
: "${LLAMA_MODEL:=${LLAMA_MODELS_DIR}/unsloth/Qwen3.5-9B-GGUF/Qwen3.5-9B-Q4_K_M.gguf}"
: "${LLAMA_MMPROJ:=${LLAMA_MODELS_DIR}/unsloth/Qwen3.5-9B-GGUF/mmproj-F32.gguf}"

: "${LLAMA_PORT:=18080}"
: "${LLAMA_CTX_SIZE:=32768}"
: "${LLAMA_N_GPU_LAYERS:=999999}"
: "${LLAMA_OVERRIDE_KV:=}"
: "${LLAMA_REASONING:=off}"
LLAMA_THREADS="8"
LLAMA_PARALLEL="4"


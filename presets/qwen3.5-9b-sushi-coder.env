# Qwen3.5-9b-Sushi-Coder-RL (bigatuna, Q4_K_M) — good but not fast. Alt for A/B
# testing against qwen3.5-9b.env. Runs on its own port so both can be up at once.
: "${LLAMA_MODEL:=${LLAMA_MODELS_DIR}/bigatuna/Qwen3.5-9b-Sushi-Coder-RL-GGUF/Qwen3.5-9b-Sushi-Coder-RL.Q4_K_M.gguf}"
: "${LLAMA_MMPROJ:=}"

: "${LLAMA_PORT:=18083}"
: "${LLAMA_CTX_SIZE:=32768}"
: "${LLAMA_N_GPU_LAYERS:=999999}"
: "${LLAMA_OVERRIDE_KV:=}"
: "${LLAMA_REASONING:=off}"

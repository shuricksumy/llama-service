# Gemma-4 E4B-it (lmstudio-community, Q4_K_M) — alt source/quant, for A/B testing
# against gemma-4b-e4b.env. Runs on its own port so both can be up at once.
: "${LLAMA_MODEL:=${LLAMA_MODELS_DIR}/lmstudio-community/gemma-4-E4B-it-GGUF/gemma-4-E4B-it-Q4_K_M.gguf}"
: "${LLAMA_MMPROJ:=${LLAMA_MODELS_DIR}/lmstudio-community/gemma-4-E4B-it-GGUF/mmproj-gemma-4-E4B-it-BF16.gguf}"

: "${LLAMA_PORT:=18081}"
: "${LLAMA_CTX_SIZE:=32768}"
: "${LLAMA_N_GPU_LAYERS:=999999}"
: "${LLAMA_OVERRIDE_KV:=}"
: "${LLAMA_REASONING:=on}"
